# SearchX Backend Environment Configuration

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS (comma-separated URLs)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Storage paths (relative to backend directory)
STORAGE_DIR=storage/files
THUMBNAILS_DIR=storage/thumbnails
EMBEDDINGS_DIR=storage/embeddings
VECTOR_INDEX_PATH=storage/faiss_index

# Database
DATABASE_URL=sqlite:///searchx.db

# File upload limits
MAX_FILE_SIZE=52428800

# Embedding model settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
USE_GPU=False

# OCR settings
TESSERACT_PATH=
OCR_LANGUAGES=eng

# Search settings
SIMILARITY_THRESHOLD=0.1
